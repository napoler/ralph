# Ralph 配置文件示例
# ============================================
# 复制此文件为 ralph.conf 并修改配置
# ============================================

# ---------- 项目配置 ----------
# 项目目录 (必需)
RALPH_PROJECT_DIR="/mnt/data/dev/decentralized-box"

# ---------- 运行配置 ----------
# 默认 AI 工具
RALPH_TOOL="qwen"

# 最大迭代次数
RALPH_MAX_ITERATIONS=10

# 启用负载均衡 (true/false)
RALPH_LOAD_BALANCE="true"

# 完成信号
RALPH_COMPLETE_SIGNAL="<promise>COMPLETE</promise>"

# ---------- 目录配置 ----------
# 日志目录 (支持日期变量)
RALPH_LOG_DIR="/mnt/data/dev/tmp/ralph-$(date +%Y%m%d)/logs"

# 工作树根目录
RALPH_WORKTREE_ROOT="/mnt/data/dev/tmp"

# 基础分支
RALPH_BASE_BRANCH="dev"

# ---------- 任务类型映射 ----------
# 关键词 -> 工具 映射
# 可在此添加自定义映射
# 示例:
# RALPH_TASK_MAPPING["mykeyword"]="opencode"