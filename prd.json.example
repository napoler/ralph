{
  "project": "MyApp",
  "branchName": "ralph/task-priority",
  "description": "Task Priority System - Add priority levels to tasks",
  "spec": {
    "constitution": [
      "Spec-Driven Development: 规范先于代码",
      "Small Iterations: 每个任务可在一轮迭代内完成",
      "Verified: 每个验收标准必须可自动化验证",
      "CI Green: 保持持续集成通过"
    ],
    "dependencies": {
      "database": "required",
      "testing": "recommended",
      "browser": "optional"
    }
  },
  "userStories": [
    {
      "id": "US-001",
      "title": "Add priority field to database",
      "description": "As a developer, I need to store task priority so it persists across sessions.",
      "spec": {
        "research": "检查现有数据库schema和migration工具",
        "plan": "创建migration添加priority字段",
        "implementation": "执行migration并验证"
      },
      "acceptanceCriteria": [
        "Add priority column to tasks table: 'high' | 'medium' | 'low' (default 'medium')",
        "Generate and run migration successfully",
        "Typecheck passes"
      ],
      "priority": 1,
      "passes": false,
      "notes": ""
    },
    {
      "id": "US-002",
      "title": "Display priority indicator on task cards",
      "description": "As a user, I want to see task priority at a glance.",
      "spec": {
        "research": "检查现有task card组件结构",
        "plan": "添加priority badge组件",
        "implementation": "集成到task card"
      },
      "acceptanceCriteria": [
        "Each task card shows colored priority badge (red=high, yellow=medium, gray=low)",
        "Priority visible without hovering or clicking",
        "Typecheck passes",
        "Verify in browser using dev-browser skill"
      ],
      "priority": 2,
      "passes": false,
      "notes": ""
    },
    {
      "id": "US-003",
      "title": "Add priority selector to task edit",
      "description": "As a user, I want to change a task's priority when editing it.",
      "spec": {
        "research": "检查task edit modal实现",
        "plan": "添加priority dropdown组件",
        "implementation": "集成到edit modal"
      },
      "acceptanceCriteria": [
        "Priority dropdown in task edit modal",
        "Shows current priority as selected",
        "Saves immediately on selection change",
        "Typecheck passes",
        "Verify in browser using dev-browser skill"
      ],
      "priority": 3,
      "passes": false,
      "notes": ""
    },
    {
      "id": "US-004",
      "title": "Filter tasks by priority",
      "description": "As a user, I want to filter the task list to see only high-priority items.",
      "spec": {
        "research": "检查现有filter实现",
        "plan": "添加priority filter",
        "implementation": "集成filter到task list"
      },
      "acceptanceCriteria": [
        "Filter dropdown with options: All | High | Medium | Low",
        "Filter persists in URL params",
        "Empty state message when no tasks match filter",
        "Typecheck passes",
        "Verify in browser using dev-browser skill"
      ],
      "priority": 4,
      "passes": false,
      "notes": ""
    }
  ]
}